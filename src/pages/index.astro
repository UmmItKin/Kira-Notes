---
const lastUpdated = '1999-07-31 23:42:10 HKT';
const tools = [
	['deathscan.exe', 'port scanner', 'offline'],
	['ryuk-ping.zip', 'icmp mapper', 'broken'],
	['notebook-crack.tgz', 'hash cracker', 'fake'],
	['eyeswap.bin', 'license patcher', 'mirror down'],
	['kira-sniff.tar.gz', 'packet capture', 'md5 fail'],
	['shinigami-keygen.exe', 'serial generator', 'triple-hash'],
	['L-crypt.dll', 'encryption library', 'untested'],
	['deathnote-rootkit.tgz', 'kernel module', 'never worked'],
];
const mirrors = ['hk0.dark', 'jp2.dead', 'us9.null', 'eu1.void', 'uk5.ghost'];
const news = [
	'new exploit pack delayed again',
	'guestbook temporarily disabled after spam flood',
	'old mirrors may return checksum mismatch',
	'download server migrating to new host',
];
const changelog = [
	'v0.9 — added mirrors section',
	'v0.8 — fixed md5 checksums',
	'v0.7 — removed broken links',
];
const guests = ['zero_cool', 'acidburn', 'nobody', 'kira'];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="author" content="kira@darknet.void" />
		<meta name="description" content="underground hacker tools archive — kira notes — warez repository" />
	</head>
	<body class="min-h-screen bg-terminal text-phosphor font-terminal [background-image:radial-gradient(#39ff141a_1px,transparent_1px)] [background-size:18px_18px]">
		<div class="pointer-events-none fixed inset-0 opacity-20 [background:repeating-linear-gradient(0deg,transparent_0_2px,#39ff14_3px)]"></div>
		<main class="mx-auto max-w-1100px px-4 py-6">
			<header class="mb-4 border border-phosphor px-4 py-2">
				<nav class="flex flex-wrap items-center justify-between gap-4 text-2xl">
					<span class="text-amber">visitors: 00001337</span>
					<div class="flex flex-wrap gap-4">
					<a href="#tools" class="underline decoration-dotted">tools</a>
					<a href="#mirrors" class="underline decoration-dotted">mirrors</a>
					<a href="#guestbook" class="underline decoration-dotted">guestbook</a>
					<a href="#contact" class="underline decoration-dotted">contact</a>
					</div>
				</nav>
			</header>
			<p class="text-amber text-2xl"><span class="animate-pulse">_</span> [ KIRA-NOTES // warez tools index ]</p>
			<h1 class="text-7xl leading-none tracking-wide">KIRA NOTES</h1>
			<pre class="my-4 overflow-x-auto border border-phosphor bg-black/50 p-3 font-mono text-sm leading-tight text-phosphor">
 __  ___ ___   ___        _   _  ___ _____ ___ ___ 
|  \/  |/ _ \ / _ \      | \ | |/ _ \_   _| __/ __|
| |\/| | (_) | (_) |     |  \| | (_) || | | _|\__ \
|_|  |_|\___/ \___/      |_|\_|\___/ |_| |___|___/
			</pre>
			<p class="mt-2 text-2xl">last update: {lastUpdated}</p>
			<div class="mt-4 border-y border-amber py-2 text-2xl text-amber">
				<marquee scrollamount="6">!!! no refunds /// no support /// all downloads are fake /// do not trust mirrors !!!</marquee>
			</div>
			<section id="tools" class="mt-6 border border-phosphor bg-panel/70 p-4">
				<h2 class="mb-3 text-4xl text-amber">:: downloads</h2>
				<ul class="space-y-2 text-2xl">
					{tools.map(([name, desc, status]) => (
						<li class="grid grid-cols-[1fr_1fr_auto] gap-3 border-b border-phosphor/30 pb-1">
							<a href="#" class="underline decoration-dotted">{name}</a>
							<span>{desc}</span>
							<span class="text-amber">[{status}]</span>
						</li>
					))}
				</ul>
			</section>
			<section class="mt-4 border border-phosphor bg-black/70 p-4 font-mono text-sm">
				<p>$ ./kira-tools --list</p>
				<p>loading mirrors... failed</p>
				<p>checking signatures... mismatch</p>
				<p>status: read-only archive</p>
			</section>
			<section id="mirrors" class="mt-4 border border-phosphor bg-black/40 p-4">
				<h2 class="mb-3 text-4xl text-amber">:: mirrors</h2>
				<div class="grid grid-cols-2 gap-2 text-2xl md:grid-cols-4">
					{mirrors.map((mirror) => <span class="border border-phosphor/40 px-2 py-1">{mirror}</span>)}
				</div>
			</section>
			<section class="mt-4 border border-phosphor bg-black/40 p-4">
				<h2 class="mb-3 text-4xl text-amber">:: changelog</h2>
				<ul class="list-inside list-[square] text-2xl">
					{changelog.map((item) => <li>{item}</li>)}
				</ul>
			</section>
			<section class="mt-4 border border-amber bg-black/40 p-4">
				<h2 class="mb-3 text-4xl text-amber">:: board</h2>
				<ul class="list-inside list-[square] text-2xl">
					{news.map((item) => <li>{item}</li>)}
				</ul>
			</section>
			<section id="guestbook" class="mt-4 border border-phosphor bg-panel/70 p-4">
				<h2 class="mb-3 text-4xl text-amber">:: guestbook</h2>
				<p class="mb-2 text-2xl">last visitors:</p>
				<p class="break-words text-2xl">{guests.join('  //  ')}</p>
			</section>
			<section id="contact" class="mt-4 border border-phosphor bg-panel/70 p-4">
				<h2 class="mb-3 text-4xl text-amber">:: contact</h2>
				<p class="text-2xl">email: kira@darknet.void</p>
				<p class="text-2xl">irc: #kira-notes @ irc.darknet.void</p>
				<p class="text-2xl">pgp: 0xDEADBEEF1337</p>
			</section>
		</main>
		<footer class="mx-auto max-w-1100px px-4 py-4 border-t border-phosphor/40 mt-6">
			<div class="flex justify-center gap-4 mb-3 text-xl">
				<span class="border border-amber px-2 py-1 text-amber">MADE WITH NOTEPAD</span>
				<span class="border border-phosphor px-2 py-1">NO JS REQUIRED</span>
				<span class="border border-blue px-2 py-1 text-blue">GIGAHERTZ VERIFIED</span>
			</div>
			<p class="text-2xl text-center">best viewed in Netscape Navigator 4.7 @ 800x600</p>
			<p class="text-center mt-2 text-xl text-amber">[ under_construction ]</p>
		</footer>
	</body>
</html>
